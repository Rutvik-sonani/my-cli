{
  "name": "mycli",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Node.js/TypeScript application development platform — Laravel Artisan for Node.js",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "e2e:generated": "node scripts/e2e-generated-app.mjs",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:prettier": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "my": "pnpm --filter @mycli-cli/cli start",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.4.2",
    "turbo": "^2.10.6",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  }
}
