    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mycli/plugin-system": "workspace:*",
    "@mycli/deployment-manager": "workspace:*",
    "@mycli/cloud-manager": "workspace:*",
    "@mycli/filesystem": "workspace:*",
    "@mycli/template-engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.5"
  }
}
