{
  "name": "@mycli/plugin-fly",
  "version": "1.0.0",
  "description": "Official MyCLI Fly.io deployment plugin",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
