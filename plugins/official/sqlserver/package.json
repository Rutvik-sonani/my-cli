{
  "name": "@mycli-cli/plugin-sqlserver",
  "version": "1.0.0",
  "description": "Official MyCLI sqlserver plugin",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mycli-cli/plugin-system": "workspace:*",
    "@mycli-cli/database-manager": "workspace:*",
    "@mycli-cli/filesystem": "workspace:*",
    "@mycli-cli/template-engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.5"
  }
}
