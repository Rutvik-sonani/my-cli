{
  "name": "@community/plugin-hello-mycli",
  "version": "1.0.1",
  "description": "Example community MyCLI plugin",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mycli-cli/plugin-system": "workspace:*",
    "@mycli-cli/filesystem": "workspace:*"
  },
  "devDependencies": {
    "@mycli-cli/config-manager": "workspace:*",
    "@mycli-cli/core": "workspace:*",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "@types/node": "^26.1.1"
  }
}
