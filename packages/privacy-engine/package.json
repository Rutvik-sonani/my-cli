{
  "name": "@mycli-cli/privacy-engine",
  "version": "1.0.1",
  "description": "Enterprise privacy management scaffolding and runtime for MyCLI",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@mycli-cli/core": "workspace:*",
    "@mycli-cli/enterprise-core": "workspace:*",
    "@mycli-cli/filesystem": "workspace:*",
    "@mycli-cli/template-engine": "workspace:*"
  },
  "devDependencies": {
    "@mycli-cli/config-manager": "workspace:*",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
