import { Create<%= pascal %>Command, Create<%= pascal %>Handler } from '../commands/Create<%= pascal %>Command.js';
import { Get<%= pascal %>Query, Get<%= pascal %>Handler } from '../queries/Get<%= pascal %>Query.js';

<% if (language === 'javascript') { %>
export class <%= pascal %>ApplicationService {
  constructor(repository) {
    this.createHandler = new Create<%= pascal %>Handler(repository);
    this.getHandler = new Get<%= pascal %>Handler(repository);
