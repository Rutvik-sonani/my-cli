<% if (language === 'javascript') { %>
import { DatabaseFeatureFlagProvider } from './database.provider.js';

/**
 * Unleash adapter for <%= appName %>.
 * Wire `unleash-client` with UNLEASH_URL / UNLEASH_API_TOKEN in production.
 * Falls back to local evaluation until the client is connected.
 */
export class UnleashFeatureFlagProvider {
  constructor() {
    this.id = 'unleash';
    this.fallback = new DatabaseFeatureFlagProvider();
  }

  async connect() {
    // TODO: initialize Unleash client with process.env.UNLEASH_URL
    await this.fallback.connect();
  }

  async disconnect() {
    await this.fallback.disconnect();
  }

  evaluate(key, context) {
    return this.fallback.evaluate(key, context);
  }

  isEnabled(key, context) {
    return this.fallback.isEnabled(key, context);
  }
}
<% } else { %>
import type { FeatureFlagProvider } from '../feature-flag-provider.interface.js';
import type {
  FeatureFlagContext,
  FeatureFlagEvaluation,
  FeatureFlagProviderId,
} from '../feature-flag.types.js';
import { DatabaseFeatureFlagProvider } from './database.provider.js';

/**
 * Unleash adapter for <%= appName %>.
 * Wire `unleash-client` with UNLEASH_URL / UNLEASH_API_TOKEN in production.
 * Falls back to local evaluation until the client is connected.
 */
export class UnleashFeatureFlagProvider implements FeatureFlagProvider {
  readonly id: FeatureFlagProviderId = 'unleash';
  private readonly fallback = new DatabaseFeatureFlagProvider();

  async connect(): Promise<void> {
    // TODO: initialize Unleash client with process.env.UNLEASH_URL
    await this.fallback.connect();
  }

  async disconnect(): Promise<void> {
    await this.fallback.disconnect();
  }

  evaluate(key: string, context?: FeatureFlagContext): Promise<FeatureFlagEvaluation> {
    return this.fallback.evaluate(key, context);
  }

  isEnabled(key: string, context?: FeatureFlagContext): Promise<boolean> {
    return this.fallback.isEnabled(key, context);
  }
}
<% } %>
