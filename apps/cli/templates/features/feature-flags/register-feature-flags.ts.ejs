const provider = new LaunchDarklyFeatureFlagProvider();
<% } else if (isUnleash) { -%>
import { UnleashFeatureFlagProvider } from './providers/unleash.provider.js';
const provider = new UnleashFeatureFlagProvider();
<% } else { -%>
import { DatabaseFeatureFlagProvider } from './providers/database.provider.js';
