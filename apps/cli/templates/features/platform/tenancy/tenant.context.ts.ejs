import { AsyncLocalStorage } from 'node:async_hooks';

export interface TenantContext {
  tenantId: string;
  schema?: string;
  databaseUrl?: string;
}

const storage = new AsyncLocalStorage<TenantContext>();

export function runWithTenant<T>(tenantId: string, fn: () => T, meta: Partial<TenantContext> = {}): T {
  return storage.run({ tenantId, ...meta }, fn);
}

export function getTenantId(): string {
  return storage.getStore()?.tenantId ?? process.env.DEFAULT_TENANT ?? 'default';
}

export function getTenantSchema(): string | undefined {
  return storage.getStore()?.schema;
}

export function getTenantDatabaseUrl(): string | undefined {
  return storage.getStore()?.databaseUrl;
}

export function setTenantContext(tenantId: string, meta: Partial<TenantContext> = {}): void {
  storage.enterWith({ tenantId, ...meta });
}
