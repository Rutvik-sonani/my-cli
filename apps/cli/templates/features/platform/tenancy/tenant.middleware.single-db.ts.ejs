import type { FastifyInstance, FastifyRequest } from 'fastify';
import { setTenantContext } from './tenant.context.js';

const HEADER = process.env.TENANT_HEADER ?? 'x-tenant-id';

/** Single-database tenancy: tenant id in shared DB (row-level / app filtering). */
export async function registerTenancyMiddleware(app: FastifyInstance): Promise<void> {
  app.addHook('onRequest', async (request: FastifyRequest) => {
    const header = request.headers[HEADER.toLowerCase()];
    const tenantId =
      (typeof header === 'string' ? header : Array.isArray(header) ? header[0] : undefined) ??
      process.env.DEFAULT_TENANT ??
      'default';
    setTenantContext(tenantId);
  });
}
