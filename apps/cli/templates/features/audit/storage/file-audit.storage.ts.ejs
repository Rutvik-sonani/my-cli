<% if (language === 'javascript') { %>
import { appendFile, mkdir, readFile } from 'node:fs/promises';
import { dirname } from 'node:path';

export class FileAuditStorage {
  constructor(filePath = process.env.AUDIT_FILE_PATH ?? './data/audit.log.jsonl') {
    this.filePath = filePath;
    this.cache = [];
  }

  async save(record) {
    await mkdir(dirname(this.filePath), { recursive: true });
    const line = JSON.stringify({ ...record, timestamp: record.timestamp.toISOString() });
    await appendFile(this.filePath, `${line}\n`, 'utf8');
    this.cache.push(record);
  }

  async findByResource(resource) {
    await this.loadCache();
    return this.cache.filter((record) => record.resource === resource);
  }

  async findByUser(userId) {
    await this.loadCache();
    return this.cache.filter((record) => record.userId === userId);
  }

  async list(limit = 100) {
    await this.loadCache();
    return this.cache.slice(-limit);
  }

  async loadCache() {
    if (this.cache.length > 0) return;
    try {
      const raw = await readFile(this.filePath, 'utf8');
      this.cache = raw
        .split('\n')
        .filter(Boolean)
        .map((line) => {
          const parsed = JSON.parse(line);
          return { ...parsed, timestamp: new Date(parsed.timestamp) };
        });
    } catch {
      this.cache = [];
    }
  }
}
<% } else { %>
import { appendFile, mkdir, readFile } from 'node:fs/promises';
import { dirname } from 'node:path';
import type { AuditRecord } from '../audit-record.js';
import type { AuditStorage } from './audit-storage.interface.js';

export class FileAuditStorage implements AuditStorage {
  private readonly filePath: string;
  private cache: AuditRecord[] = [];

  constructor(filePath = process.env.AUDIT_FILE_PATH ?? './data/audit.log.jsonl') {
    this.filePath = filePath;
  }

  async save(record: AuditRecord): Promise<void> {
    await mkdir(dirname(this.filePath), { recursive: true });
    const line = JSON.stringify({ ...record, timestamp: record.timestamp.toISOString() });
    await appendFile(this.filePath, `${line}\n`, 'utf8');
    this.cache.push(record);
  }

  async findByResource(resource: string): Promise<AuditRecord[]> {
    await this.loadCache();
    return this.cache.filter((record) => record.resource === resource);
  }

  async findByUser(userId: string): Promise<AuditRecord[]> {
    await this.loadCache();
    return this.cache.filter((record) => record.userId === userId);
  }

  async list(limit = 100): Promise<AuditRecord[]> {
    await this.loadCache();
    return this.cache.slice(-limit);
  }

  private async loadCache(): Promise<void> {
    if (this.cache.length > 0) return;
    try {
      const raw = await readFile(this.filePath, 'utf8');
      this.cache = raw
        .split('\n')
        .filter(Boolean)
        .map((line) => {
          const parsed = JSON.parse(line) as AuditRecord & { timestamp: string };
          return { ...parsed, timestamp: new Date(parsed.timestamp) };
        });
    } catch {
      this.cache = [];
    }
  }
}
<% } %>
