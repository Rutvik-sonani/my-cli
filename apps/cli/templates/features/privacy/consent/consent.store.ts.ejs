<% if (language === 'javascript') { %>
export class ConsentStore {
  constructor() {
    this.records = [];
  }

  async record(userId, purpose, status, options = {}) {
    const entry = {
      id: crypto.randomUUID(),
      userId,
      purpose,
      status,
      recordedAt: new Date(),
      source: options.source,
      metadata: options.metadata,
    };
    this.records.push(entry);
    return entry;
  }

  async listByUser(userId) {
    return this.records.filter((record) => record.userId === userId);
  }

  async deleteByUser(userId) {
    let removed = 0;
    for (let i = this.records.length - 1; i >= 0; i -= 1) {
      if (this.records[i]?.userId === userId) {
        this.records.splice(i, 1);
        removed += 1;
      }
    }
    return removed;
  }
}
<% } else { %>
import type { ConsentRecord, ConsentStatus } from '../privacy.types.js';

export class ConsentStore {
  private readonly records: ConsentRecord[] = [];

  async record(
    userId: string,
    purpose: string,
    status: ConsentStatus,
    options: { source?: string; metadata?: Record<string, unknown> } = {},
  ): Promise<ConsentRecord> {
    const entry: ConsentRecord = {
      id: crypto.randomUUID(),
      userId,
      purpose,
      status,
      recordedAt: new Date(),
      source: options.source,
      metadata: options.metadata,
    };
    this.records.push(entry);
    return entry;
  }

  async listByUser(userId: string): Promise<ConsentRecord[]> {
    return this.records.filter((record) => record.userId === userId);
  }

  async deleteByUser(userId: string): Promise<number> {
    let removed = 0;
    for (let i = this.records.length - 1; i >= 0; i -= 1) {
      if (this.records[i]?.userId === userId) {
        this.records.splice(i, 1);
        removed += 1;
      }
    }
    return removed;
  }
}
<% } %>
