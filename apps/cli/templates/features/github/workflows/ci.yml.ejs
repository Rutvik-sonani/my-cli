name: CI

on:
  push:
    branches: [<%= branch %>]
  pull_request:
    branches: [<%= branch %>]

jobs:
  quality:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: <%= nodeVersion %>
          cache: '<%= packageManager %>'
      - run: <%= installCommand %>
      - run: <%= lintCommand %>
      - run: <%= testCommand %>
      - run: <%= buildCommand %>
