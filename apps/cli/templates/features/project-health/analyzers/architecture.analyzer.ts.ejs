<% if (language === 'javascript') { %>
/**
 * @param {{ architectureStyle?: string, existingPaths?: string[] }} snapshot
 * @returns {import('../health.types.js').HealthFinding[]}
 */
export function analyzeArchitecture(snapshot) {
  const findings = [];
  if (snapshot.architectureStyle) {
    findings.push({
      id: 'arch-style',
      category: 'architecture',
      status: 'pass',
      title: 'Architecture style configured',
      message: `Using \`${snapshot.architectureStyle}\`.`,
    });
  } else {
    findings.push({
      id: 'arch-style',
      category: 'architecture',
      status: 'warn',
      title: 'Architecture style missing',
      message: 'No architectureStyle configured.',
    });
  }
  return findings;
}
<% } else { %>
