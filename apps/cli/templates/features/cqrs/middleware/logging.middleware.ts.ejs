<% if (language === 'javascript') { %>
export function createLoggingMiddleware(label, logger = console) {
  return async (message, next) => {
    const started = Date.now();
    logger.info?.(`[cqrs:${label}] start`, { type: message.type });
    try {
      const result = await next();
      logger.info?.(`[cqrs:${label}] done`, { type: message.type, ms: Date.now() - started });
      return result;
    } catch (error) {
      logger.error?.(`[cqrs:${label}] failed`, {
        type: message.type,
        ms: Date.now() - started,
        error: error instanceof Error ? error.message : String(error),
      });
      throw error;
    }
  };
}
<% } else { %>
export interface LoggerLike {
  info(message: string, meta?: Record<string, unknown>): void;
  error(message: string, meta?: Record<string, unknown>): void;
}

const defaultLogger: LoggerLike = {
  info(message, meta) {
    console.log(message, meta ?? '');
  },
  error(message, meta) {
    console.error(message, meta ?? '');
  },
};

export type BusMiddleware<T> = (message: T, next: () => Promise<unknown>) => Promise<unknown>;

export function createLoggingMiddleware(
  label: 'command' | 'query' | 'event',
  logger: LoggerLike = defaultLogger,
): BusMiddleware<{ type: string }> {
  return async (message, next) => {
    const started = Date.now();
    logger.info(`[cqrs:${label}] start`, { type: message.type });
    try {
      const result = await next();
      logger.info(`[cqrs:${label}] done`, { type: message.type, ms: Date.now() - started });
      return result;
    } catch (error) {
      logger.error(`[cqrs:${label}] failed`, {
        type: message.type,
        ms: Date.now() - started,
        error: error instanceof Error ? error.message : String(error),
      });
      throw error;
    }
  };
}
<% } %>
