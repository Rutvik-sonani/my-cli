<% if (language === 'javascript') { %>
import Redis from 'ioredis';
import { JsonEventSerializer } from '../serializer.js';
import { withRetry } from '../retry.policy.js';
import { DeadLetterQueue } from '../dead-letter/dead-letter.queue.js';

export class RedisEventConsumer {
  constructor(options = {}) {
    this.stream = options.stream ?? process.env.REDIS_STREAM ?? '<%= appName %>:events';
    this.group = options.group ?? '<%= appName %>-consumers';
    this.consumer = options.consumer ?? '<%= appName %>-worker';
    this.redis = options.redis ?? new Redis(process.env.REDIS_URL ?? 'redis://localhost:6379');
    this.serializer = new JsonEventSerializer();
    this.handlers = new Map();
    this.deadLetter = new DeadLetterQueue();
  }

  on(type, handler) {
    const list = this.handlers.get(type) ?? [];
    list.push(handler);
    this.handlers.set(type, list);
  }

  async start() {
    try {
      await this.redis.xgroup('CREATE', this.stream, this.group, '0', 'MKSTREAM');
    } catch {
      // group exists
    }

    for (;;) {
      const rows = await this.redis.xreadgroup(
        'GROUP',
        this.group,
        this.consumer,
        'COUNT',
        10,
        'BLOCK',
        2000,
        'STREAMS',
        this.stream,
        '>',
      );
      if (!rows) continue;

      for (const [, messages] of rows) {
        for (const [id, fields] of messages) {
          const raw = fields[fields.indexOf('event') + 1];
          try {
            const envelope = this.serializer.deserialize(raw);
            const handlers = this.handlers.get(envelope.type) ?? [];
            for (const handler of handlers) {
              await withRetry(() => handler(envelope));
            }
            await this.redis.xack(this.stream, this.group, id);
          } catch (error) {
            this.deadLetter.push(this.serializer.deserialize(raw), error);
          }
        }
      }
    }
  }
}
<% } else { %>
import Redis from 'ioredis';
import { JsonEventSerializer, type EventEnvelope } from '../serializer.js';
import { withRetry } from '../retry.policy.js';
import { DeadLetterQueue } from '../dead-letter/dead-letter.queue.js';

export class RedisEventConsumer {
  private readonly handlers = new Map<string, Array<(envelope: EventEnvelope) => Promise<void>>>();
  private readonly redis: Redis;
  private readonly stream: string;
  private readonly group: string;
  private readonly consumer: string;
  private readonly serializer = new JsonEventSerializer();
  readonly deadLetter = new DeadLetterQueue();

  constructor(options: { redis?: Redis; stream?: string; group?: string; consumer?: string } = {}) {
    this.stream = options.stream ?? process.env.REDIS_STREAM ?? '<%= appName %>:events';
    this.group = options.group ?? '<%= appName %>-consumers';
    this.consumer = options.consumer ?? '<%= appName %>-worker';
    this.redis = options.redis ?? new Redis(process.env.REDIS_URL ?? 'redis://localhost:6379');
  }

  on<T>(type: string, handler: (envelope: EventEnvelope<T>) => Promise<void>): void {
    const list = this.handlers.get(type) ?? [];
    list.push(handler as (envelope: EventEnvelope) => Promise<void>);
    this.handlers.set(type, list);
  }

  async start(): Promise<void> {
    try {
      await this.redis.xgroup('CREATE', this.stream, this.group, '0', 'MKSTREAM');
    } catch {
      // group already exists
    }

    for (;;) {
      const rows = await this.redis.xreadgroup(
        'GROUP',
        this.group,
        this.consumer,
        'COUNT',
        10,
        'BLOCK',
        2000,
        'STREAMS',
        this.stream,
        '>',
      );
      if (!rows) continue;

      for (const [, messages] of rows) {
        for (const [id, fields] of messages) {
          const eventIndex = fields.indexOf('event');
          const raw = eventIndex >= 0 ? String(fields[eventIndex + 1]) : '';
          try {
            const envelope = this.serializer.deserialize(raw);
            const handlers = this.handlers.get(envelope.type) ?? [];
            for (const handler of handlers) {
              await withRetry(async () => handler(envelope));
            }
            await this.redis.xack(this.stream, this.group, id);
          } catch (error) {
            this.deadLetter.push(this.serializer.deserialize(raw), error);
          }
        }
      }
    }
  }
}
<% } %>
