<% if (language === 'javascript') { %>
import amqp from 'amqplib';
import { JsonEventSerializer } from '../serializer.js';
import { withRetry } from '../retry.policy.js';
import { DeadLetterQueue } from '../dead-letter/dead-letter.queue.js';

export class RabbitEventConsumer {
  constructor(options = {}) {
    this.exchange = options.exchange ?? process.env.RABBITMQ_EXCHANGE ?? '<%= appName %>.events';
    this.queue = options.queue ?? '<%= appName %>.events.queue';
    this.url = options.url ?? process.env.RABBITMQ_URL ?? 'amqp://guest:guest@localhost:5672';
    this.serializer = new JsonEventSerializer();
    this.handlers = new Map();
    this.deadLetter = new DeadLetterQueue();
  }

  on(type, handler) {
    const list = this.handlers.get(type) ?? [];
    list.push(handler);
    this.handlers.set(type, list);
  }

  async start() {
    const connection = await amqp.connect(this.url);
    const channel = await connection.createChannel();
    await channel.assertExchange(this.exchange, 'topic', { durable: true });
    await channel.assertQueue(this.queue, { durable: true });
    await channel.bindQueue(this.queue, this.exchange, '#');

    await channel.consume(this.queue, async (message) => {
      if (!message) return;
      const raw = message.content.toString();
      try {
        const envelope = this.serializer.deserialize(raw);
        const handlers = this.handlers.get(envelope.type) ?? [];
        for (const handler of handlers) {
          await withRetry(() => handler(envelope));
        }
        channel.ack(message);
      } catch (error) {
        this.deadLetter.push(this.serializer.deserialize(raw), error);
        channel.nack(message, false, false);
      }
    });
  }
}
<% } else { %>
import amqp from 'amqplib';
import { JsonEventSerializer, type EventEnvelope } from '../serializer.js';
import { withRetry } from '../retry.policy.js';
import { DeadLetterQueue } from '../dead-letter/dead-letter.queue.js';

export class RabbitEventConsumer {
  private readonly exchange: string;
  private readonly queue: string;
  private readonly url: string;
  private readonly serializer = new JsonEventSerializer();
  private readonly handlers = new Map<string, Array<(envelope: EventEnvelope) => Promise<void>>>();
  readonly deadLetter = new DeadLetterQueue();

  constructor(options: { url?: string; exchange?: string; queue?: string } = {}) {
    this.exchange = options.exchange ?? process.env.RABBITMQ_EXCHANGE ?? '<%= appName %>.events';
    this.queue = options.queue ?? '<%= appName %>.events.queue';
    this.url = options.url ?? process.env.RABBITMQ_URL ?? 'amqp://guest:guest@localhost:5672';
  }

  on<T>(type: string, handler: (envelope: EventEnvelope<T>) => Promise<void>): void {
    const list = this.handlers.get(type) ?? [];
    list.push(handler as (envelope: EventEnvelope) => Promise<void>);
    this.handlers.set(type, list);
  }

  async start(): Promise<void> {
    const connection = await amqp.connect(this.url);
    const channel = await connection.createChannel();
    await channel.assertExchange(this.exchange, 'topic', { durable: true });
    await channel.assertQueue(this.queue, { durable: true });
    await channel.bindQueue(this.queue, this.exchange, '#');

    await channel.consume(this.queue, async (message) => {
      if (!message) return;
      const raw = message.content.toString();
      try {
        const envelope = this.serializer.deserialize(raw);
        const handlers = this.handlers.get(envelope.type) ?? [];
        for (const handler of handlers) {
          await withRetry(async () => handler(envelope));
        }
        channel.ack(message);
      } catch (error) {
        this.deadLetter.push(this.serializer.deserialize(raw), error);
        channel.nack(message, false, false);
      }
    });
  }
}
<% } %>
