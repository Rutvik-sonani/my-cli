import { describe, expect, it } from 'vitest';
import { JsonEventSerializer, createEventEnvelope } from '../../src/event-system/serializer.js';
import { withRetry } from '../../src/event-system/retry.policy.js';
import { DeadLetterQueue } from '../../src/event-system/dead-letter/dead-letter.queue.js';
import { UserCreatedEvent } from '../../src/event-system/events/UserCreatedEvent.js';
import { handleUserCreated } from '../../src/event-system/handlers/user-created.handler.js';

describe('event-system core', () => {
  it('serializes and deserializes versioned envelopes', () => {
    const serializer = new JsonEventSerializer();
    const envelope = createEventEnvelope('user.created', { id: '1', email: 'a@b.com' }, { version: 1 });
    const parsed = serializer.deserialize(serializer.serialize(envelope));
    expect(parsed.type).toBe('user.created');
    expect(parsed.version).toBe(1);
    expect(parsed.payload).toEqual({ id: '1', email: 'a@b.com' });
  });

  it('retries failing operations', async () => {
    let attempts = 0;
    await withRetry(async () => {
      attempts += 1;
      if (attempts < 2) throw new Error('temporary');
      return 'ok';
    }, { maxAttempts: 3, baseDelayMs: 1, maxDelayMs: 2 });
    expect(attempts).toBe(2);
  });

  it('stores failed events in dead-letter queue', () => {
    const dlq = new DeadLetterQueue();
    const envelope = createEventEnvelope(UserCreatedEvent.type, { id: '1', email: 'x@y.com' });
    dlq.push(envelope, new Error('handler failed'));
    expect(dlq.all()).toHaveLength(1);
  });

  it('handles user created event payload', async () => {
    const envelope = createEventEnvelope(UserCreatedEvent.type, { id: '1', email: 'demo@example.com' });
    await expect(handleUserCreated(envelope)).resolves.toBeUndefined();
  });
});
