services:
  app:
    build: .
    ports:
      - "<%= port %>:<%= port %>"
    env_file:
      - .env
    depends_on:
<% if (database === 'postgres') { %>      - postgres
<% } %><% if (database === 'mysql') { %>      - mysql
<% } %><% if (database === 'mongodb') { %>      - mongo
<% } %><% if (redis) { %>      - redis
<% } %><% if (mailhog) { %>      - mailhog
<% } %>

<% if (database === 'postgres') { %>
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: <%= appName %>
      POSTGRES_PASSWORD: <%= appName %>
      POSTGRES_DB: <%= appName %>
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
<% } %>
<% if (database === 'mysql') { %>
  mysql:
    image: mysql:8
    environment:
      MYSQL_DATABASE: <%= appName %>
      MYSQL_USER: <%= appName %>
      MYSQL_PASSWORD: <%= appName %>
      MYSQL_ROOT_PASSWORD: root
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
<% } %>
<% if (database === 'mongodb') { %>
  mongo:
    image: mongo:7
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db
<% } %>
<% if (redis) { %>
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
<% } %>
<% if (mailhog) { %>
  mailhog:
    image: mailhog/mailhog:latest
    ports:
      - "1025:1025"
      - "8025:8025"
<% } %>
<% if (nginx) { %>
  nginx:
    image: nginx:alpine
    ports:
      - "80:80"
    volumes:
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - app
<% } %>

volumes:
<% if (database === 'postgres') { %>  postgres_data:
<% } %><% if (database === 'mysql') { %>  mysql_data:
<% } %><% if (database === 'mongodb') { %>  mongo_data:
<% } %>
