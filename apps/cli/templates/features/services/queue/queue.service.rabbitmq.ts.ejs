import type { ConsumeMessage } from 'amqplib';
import { getRabbitChannel } from './rabbitmq.client.js';

const prefix = process.env.QUEUE_PREFIX ?? '<%= appName %>';

export type JobHandler<T = unknown> = (job: { name: string; data: T }) => Promise<void>;

export class QueueService {
  async dispatch<T>(queueName: string, jobName: string, data: T): Promise<void> {
    const channel = await getRabbitChannel();
    const queue = `${prefix}:${queueName}`;
    await channel.assertQueue(queue, { durable: true });
    channel.sendToQueue(queue, Buffer.from(JSON.stringify({ name: jobName, data })), {
      persistent: true,
    });
  }

  async registerWorker<T>(queueName: string, handler: JobHandler<T>): Promise<void> {
    const channel = await getRabbitChannel();
    const queue = `${prefix}:${queueName}`;
    await channel.assertQueue(queue, { durable: true });
    await channel.consume(queue, async (msg: ConsumeMessage | null) => {
      if (!msg) return;
      try {
        const payload = JSON.parse(msg.content.toString()) as { name: string; data: T };
        await handler(payload);
        channel.ack(msg);
      } catch (error) {
        console.error('[queue:rabbitmq] job failed', error);
        channel.nack(msg, false, false);
      }
    });
  }
}

export const queueService = new QueueService();
