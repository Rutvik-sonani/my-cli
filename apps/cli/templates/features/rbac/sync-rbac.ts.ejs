/**
 * Sync `.mycli/rbac.json` into the database.
 * Run: pnpm exec tsx .mycli/sync-rbac.ts
 */
import { readFileSync } from 'node:fs';

interface RbacStore {
  roles: Array<{ name: string; description?: string }>;
  permissions: Array<{ name: string; description?: string }>;
  rolePermissions: Array<{ role: string; permission: string }>;
  userRoles: Array<{ userId: string; role: string }>;
}

function loadStore(): RbacStore {
  const raw = readFileSync('.mycli/rbac.json', 'utf8');
  return JSON.parse(raw) as RbacStore;
}

<% if (orm === 'prisma') { %>
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

async function main() {
  const store = loadStore();

  for (const role of store.roles) {
    await prisma.role.upsert({
      where: { name: role.name },
      create: { name: role.name, description: role.description ?? null },
      update: { description: role.description ?? null },
    });
  }

  for (const permission of store.permissions) {
    await prisma.permission.upsert({
      where: { name: permission.name },
      create: { name: permission.name, description: permission.description ?? null },
      update: { description: permission.description ?? null },
    });
  }

  for (const link of store.rolePermissions) {
    const role = await prisma.role.findUnique({ where: { name: link.role } });
    const permission = await prisma.permission.findUnique({ where: { name: link.permission } });
    if (!role || !permission) continue;
    await prisma.rolePermission.upsert({
      where: { roleId_permissionId: { roleId: role.id, permissionId: permission.id } },
      create: { roleId: role.id, permissionId: permission.id },
      update: {},
    });
  }

  for (const assignment of store.userRoles) {
    const role = await prisma.role.findUnique({ where: { name: assignment.role } });
    if (!role) continue;
    await prisma.userRole.upsert({
      where: { userId_roleId: { userId: assignment.userId, roleId: role.id } },
      create: { userId: assignment.userId, roleId: role.id },
      update: {},
    });
  }

  console.log('RBAC store synced to database.');
}

main()
  .then(() => prisma.$disconnect())
  .catch(async (error) => {
    console.error(error);
    await prisma.$disconnect();
    process.exit(1);
  });
<% } else if (orm === 'drizzle') { %>
import { eq } from 'drizzle-orm';
import { db, schema } from '../src/database/client.js';

const { roles, permissions, rolePermissions, userRoles } = schema;

async function main() {
  const store = loadStore();

  for (const role of store.roles) {
    const existing = await db.select().from(roles).where(eq(roles.name, role.name)).limit(1);
    if (existing[0]) {
      await db
        .update(roles)
        .set({ description: role.description ?? null })
        .where(eq(roles.id, existing[0].id));
    } else {
      await db.insert(roles).values({ name: role.name, description: role.description ?? null });
    }
  }

  for (const permission of store.permissions) {
    const existing = await db.select().from(permissions).where(eq(permissions.name, permission.name)).limit(1);
    if (existing[0]) {
      await db
        .update(permissions)
        .set({ description: permission.description ?? null })
        .where(eq(permissions.id, existing[0].id));
    } else {
      await db
        .insert(permissions)
        .values({ name: permission.name, description: permission.description ?? null });
    }
  }

  for (const link of store.rolePermissions) {
    const role = await db.select().from(roles).where(eq(roles.name, link.role)).limit(1);
    const permission = await db
      .select()
      .from(permissions)
      .where(eq(permissions.name, link.permission))
      .limit(1);
    if (!role[0] || !permission[0]) continue;
    await db
      .insert(rolePermissions)
      .values({ roleId: role[0].id, permissionId: permission[0].id })
      .onConflictDoNothing();
  }

  for (const assignment of store.userRoles) {
    const role = await db.select().from(roles).where(eq(roles.name, assignment.role)).limit(1);
    if (!role[0]) continue;
    await db
      .insert(userRoles)
      .values({ userId: assignment.userId, roleId: role[0].id })
      .onConflictDoNothing();
  }

  console.log('RBAC store synced to database.');
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
<% } else if (orm === 'typeorm') { %>
import 'reflect-metadata';
import { AppDataSource } from '../src/database/data-source.js';
import { Role } from '../src/database/entities/role.entity.js';
import { Permission } from '../src/database/entities/permission.entity.js';
import { RolePermission } from '../src/database/entities/role-permission.entity.js';
import { UserRole } from '../src/database/entities/user-role.entity.js';

async function main() {
  await AppDataSource.initialize();
  const store = loadStore();
  const rolesRepo = AppDataSource.getRepository(Role);
  const permissionsRepo = AppDataSource.getRepository(Permission);
  const rolePermissionsRepo = AppDataSource.getRepository(RolePermission);
  const userRolesRepo = AppDataSource.getRepository(UserRole);

  for (const role of store.roles) {
    let record = await rolesRepo.findOne({ where: { name: role.name } });
    if (record) {
      record.description = role.description ?? null;
      await rolesRepo.save(record);
    } else {
      record = rolesRepo.create({ name: role.name, description: role.description ?? null });
      await rolesRepo.save(record);
    }
  }

  for (const permission of store.permissions) {
    let record = await permissionsRepo.findOne({ where: { name: permission.name } });
    if (record) {
      record.description = permission.description ?? null;
      await permissionsRepo.save(record);
    } else {
      record = permissionsRepo.create({
        name: permission.name,
        description: permission.description ?? null,
      });
      await permissionsRepo.save(record);
    }
  }

  for (const link of store.rolePermissions) {
    const role = await rolesRepo.findOne({ where: { name: link.role } });
    const permission = await permissionsRepo.findOne({ where: { name: link.permission } });
    if (!role || !permission) continue;
    const exists = await rolePermissionsRepo.findOne({
      where: { roleId: role.id, permissionId: permission.id },
    });
    if (!exists) {
      await rolePermissionsRepo.save({ roleId: role.id, permissionId: permission.id });
    }
  }

  for (const assignment of store.userRoles) {
    const role = await rolesRepo.findOne({ where: { name: assignment.role } });
    if (!role) continue;
    const exists = await userRolesRepo.findOne({
      where: { userId: assignment.userId, roleId: role.id },
    });
    if (!exists) {
      await userRolesRepo.save({ userId: assignment.userId, roleId: role.id });
    }
  }

  await AppDataSource.destroy();
  console.log('RBAC store synced to database.');
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
<% } else if (orm === 'mongoose') { %>
import { connectDatabase } from '../src/database/connection.js';
import { RoleModel } from '../src/database/models/role.model.js';
import { PermissionModel } from '../src/database/models/permission.model.js';
import { RolePermissionModel } from '../src/database/models/role-permission.model.js';
import { UserRoleModel } from '../src/database/models/user-role.model.js';

async function main() {
  await connectDatabase();
  const store = loadStore();

  for (const role of store.roles) {
    await RoleModel.updateOne(
      { name: role.name },
      { $set: { description: role.description ?? null }, $setOnInsert: { name: role.name } },
      { upsert: true },
    );
  }

  for (const permission of store.permissions) {
    await PermissionModel.updateOne(
      { name: permission.name },
      {
        $set: { description: permission.description ?? null },
        $setOnInsert: { name: permission.name },
      },
      { upsert: true },
    );
  }

  for (const link of store.rolePermissions) {
    const role = await RoleModel.findOne({ name: link.role });
    const permission = await PermissionModel.findOne({ name: link.permission });
    if (!role || !permission) continue;
    await RolePermissionModel.updateOne(
      { roleId: String(role._id), permissionId: String(permission._id) },
      { $setOnInsert: { roleId: String(role._id), permissionId: String(permission._id) } },
      { upsert: true },
    );
  }

  for (const assignment of store.userRoles) {
    const role = await RoleModel.findOne({ name: assignment.role });
    if (!role) continue;
    await UserRoleModel.updateOne(
      { userId: assignment.userId, roleId: String(role._id) },
      { $setOnInsert: { userId: assignment.userId, roleId: String(role._id) } },
      { upsert: true },
    );
  }

  console.log('RBAC store synced to database.');
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
<% } else if (orm === 'sequelize') { %>
import { sequelize } from '../src/database/sequelize/config.js';
import { Role } from '../src/database/sequelize/models/role.model.js';
import { Permission } from '../src/database/sequelize/models/permission.model.js';
import { RolePermission } from '../src/database/sequelize/models/role-permission.model.js';
import { UserRole } from '../src/database/sequelize/models/user-role.model.js';

async function main() {
  await sequelize.sync();
  const store = loadStore();

  for (const role of store.roles) {
    const [record] = await Role.findOrCreate({
      where: { name: role.name },
      defaults: { name: role.name, description: role.description ?? null },
    });
    if (role.description !== undefined) {
      record.description = role.description ?? null;
      await record.save();
    }
  }

  for (const permission of store.permissions) {
    const [record] = await Permission.findOrCreate({
      where: { name: permission.name },
      defaults: { name: permission.name, description: permission.description ?? null },
    });
    if (permission.description !== undefined) {
      record.description = permission.description ?? null;
      await record.save();
    }
  }

  for (const link of store.rolePermissions) {
    const role = await Role.findOne({ where: { name: link.role } });
    const permission = await Permission.findOne({ where: { name: link.permission } });
    if (!role || !permission) continue;
    await RolePermission.findOrCreate({
      where: { roleId: role.id, permissionId: permission.id },
      defaults: { roleId: role.id, permissionId: permission.id },
    });
  }

  for (const assignment of store.userRoles) {
    const role = await Role.findOne({ where: { name: assignment.role } });
    if (!role) continue;
    await UserRole.findOrCreate({
      where: { userId: assignment.userId, roleId: role.id },
      defaults: { userId: assignment.userId, roleId: role.id },
    });
  }

  console.log('RBAC store synced to database.');
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
<% } else if (orm === 'mikroorm') { %>
import { MikroORM } from '@mikro-orm/core';
import config from '../src/database/mikro-orm.config.js';
import { Role } from '../src/database/entities/role.entity.js';
import { Permission } from '../src/database/entities/permission.entity.js';
import { RolePermission } from '../src/database/entities/role-permission.entity.js';
import { UserRole } from '../src/database/entities/user-role.entity.js';

async function main() {
  const orm = await MikroORM.init(config);
  const em = orm.em.fork();
  const store = loadStore();

  for (const role of store.roles) {
    let record = await em.findOne(Role, { name: role.name });
    if (record) {
      record.description = role.description ?? undefined;
    } else {
      record = em.create(Role, { name: role.name, description: role.description ?? undefined });
      em.persist(record);
    }
  }
  await em.flush();

  for (const permission of store.permissions) {
    let record = await em.findOne(Permission, { name: permission.name });
    if (record) {
      record.description = permission.description ?? undefined;
    } else {
      record = em.create(Permission, {
        name: permission.name,
        description: permission.description ?? undefined,
      });
      em.persist(record);
    }
  }
  await em.flush();

  for (const link of store.rolePermissions) {
    const role = await em.findOne(Role, { name: link.role });
    const permission = await em.findOne(Permission, { name: link.permission });
    if (!role || !permission) continue;
    const exists = await em.findOne(RolePermission, {
      roleId: role.id,
      permissionId: permission.id,
    });
    if (!exists) {
      em.persist(em.create(RolePermission, { roleId: role.id, permissionId: permission.id }));
    }
  }
  await em.flush();

  for (const assignment of store.userRoles) {
    const role = await em.findOne(Role, { name: assignment.role });
    if (!role) continue;
    const exists = await em.findOne(UserRole, { userId: assignment.userId, roleId: role.id });
    if (!exists) {
      em.persist(em.create(UserRole, { userId: assignment.userId, roleId: role.id }));
    }
  }
  await em.flush();
  await orm.close();

  console.log('RBAC store synced to database.');
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
