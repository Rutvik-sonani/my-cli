import { and, eq } from 'drizzle-orm';
import { db, schema } from '../../database/client.js';
import type { Permission, Role } from './rbac.types.js';

const { roles, permissions, rolePermissions, userRoles } = schema;

export class RbacRepository {
  async findRoleByName(name: string): Promise<Role | null> {
    const rows = await db.select().from(roles).where(eq(roles.name, name)).limit(1);
    return rows[0] ?? null;
  }

  async findPermissionByName(name: string): Promise<Permission | null> {
    const rows = await db.select().from(permissions).where(eq(permissions.name, name)).limit(1);
    return rows[0] ?? null;
  }

  async createRole(name: string, description?: string): Promise<Role> {
    const rows = await db
      .insert(roles)
      .values({ name, description: description ?? null })
      .returning();
    return rows[0]!;
  }

  async createPermission(name: string, description?: string): Promise<Permission> {
    const rows = await db
      .insert(permissions)
      .values({ name, description: description ?? null })
      .returning();
    return rows[0]!;
  }

  async assignPermission(roleId: string, permissionId: string): Promise<void> {
    await db.insert(rolePermissions).values({ roleId, permissionId }).onConflictDoNothing();
  }

  async assignRole(userId: string, roleId: string): Promise<void> {
    await db.insert(userRoles).values({ userId, roleId }).onConflictDoNothing();
  }

  async userRoles(userId: string): Promise<Role[]> {
    const links = await db.select().from(userRoles).where(eq(userRoles.userId, userId));
    const result: Role[] = [];
    for (const link of links) {
      const row = await db.select().from(roles).where(eq(roles.id, link.roleId)).limit(1);
      if (row[0]) result.push(row[0]);
    }
    return result;
  }

  async rolePermissions(roleId: string): Promise<Permission[]> {
    const links = await db.select().from(rolePermissions).where(eq(rolePermissions.roleId, roleId));
    const result: Permission[] = [];
    for (const link of links) {
      const row = await db
        .select()
        .from(permissions)
        .where(eq(permissions.id, link.permissionId))
        .limit(1);
      if (row[0]) result.push(row[0]);
    }
    return result;
  }
}
