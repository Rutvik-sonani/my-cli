{
  "name": "@mycli/cli",
  "version": "1.0.0",
  "description": "MyCLI — Laravel Artisan-style development platform for Node.js",
  "type": "module",
  "license": "MIT",
  "bin": {
    "my": "./dist/index.js"
  },
  "files": ["dist", "templates"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-cli-templates.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@mycli/audit-engine": "workspace:*",
    "@mycli/compliance-engine": "workspace:*",
    "@mycli/privacy-engine": "workspace:*",
    "@mycli/feature-flag-engine": "workspace:*",
    "@mycli/observability-engine": "workspace:*",
    "@mycli/security-engine": "workspace:*",
    "@mycli/search-engine": "workspace:*",
    "@mycli/organization-engine": "workspace:*",
    "@mycli/governance-engine": "workspace:*",
    "@mycli/template-marketplace-engine": "workspace:*",
    "@mycli/identity-engine": "workspace:*",
    "@mycli/tenancy-engine": "workspace:*",
    "@mycli/event-engine": "workspace:*",
    "@mycli/cqrs-engine": "workspace:*",
    "@mycli/domain-engine": "workspace:*",
    "@mycli/architecture-engine": "workspace:*",
    "@mycli/architecture-manager": "workspace:*",
    "@mycli/api-manager": "workspace:*",
    "@mycli/auth-manager": "workspace:*",
    "@mycli/backup-manager": "workspace:*",
    "@mycli/cli-engine": "workspace:*",
    "@mycli/command-engine": "workspace:*",
    "@mycli/config-manager": "workspace:*",
    "@mycli/core": "workspace:*",
    "@mycli/database-manager": "workspace:*",
    "@mycli/dependency-manager": "workspace:*",
    "@mycli/deployment-manager": "workspace:*",
    "@mycli/cloud-manager": "workspace:*",
    "@mycli/secrets-manager": "workspace:*",
    "@mycli/docker-manager": "workspace:*",
    "@mycli/kubernetes-manager": "workspace:*",
    "@mycli/filesystem": "workspace:*",
    "@mycli/frontend-manager": "workspace:*",
    "@mycli/generator-engine": "workspace:*",
    "@mycli/git-manager": "workspace:*",
    "@mycli/ide-manager": "workspace:*",
    "@mycli/services-manager": "workspace:*",
    "@mycli/platform-manager": "workspace:*",
    "@mycli/ai-manager": "workspace:*",
    "@mycli/plugin-sdk": "workspace:*",
    "@mycli/github-manager": "workspace:*",
    "@mycli/cicd-manager": "workspace:*",
    "@mycli/marketplace-manager": "workspace:*",
    "@mycli/registry-manager": "workspace:*",
    "@mycli/plugin-system": "workspace:*",
    "@mycli/prompt-engine": "workspace:*",
    "@mycli/rbac-manager": "workspace:*",
    "@mycli/release-manager": "workspace:*",
    "@mycli/telemetry-manager": "workspace:*",
    "@mycli/upgrade-manager": "workspace:*",
    "@mycli/migration-engine": "workspace:*",
    "@mycli/project-health-engine": "workspace:*",
    "@mycli/documentation-engine": "workspace:*",
    "@mycli/template-engine": "workspace:*",
    "@mycli/testing-manager": "workspace:*",
    "@mycli/ui-manager": "workspace:*",
    "picocolors": "^1.1.1",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
